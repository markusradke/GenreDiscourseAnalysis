\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Contingency tables comparing COMGET-G genre assignments folded with granularity 5 ot 12 to corresponding genre classification by taxonomies commonly used in MIR and computational musicology; values show $P(\text  {COMGET} \mid \text  {External})$. Additionally, we calculated relative genre prevalences and Gini coefficient across genres. Categories with less than 0.5\% relative frequency in the corpus were discarded (\textit  {Rosamerica}: \textit  {Speech}, \textit  {Discogs}: \textit  {Blues, Brass \& Military, Children's, Non-Music, Stage \& Screen}).\relax }}{10}{figure.caption.5}\protected@file@percent }
\newlabel{fig:rq3_cm_low_medium}{{4}{10}{Contingency tables comparing COMGET-G genre assignments folded with granularity 5 ot 12 to corresponding genre classification by taxonomies commonly used in MIR and computational musicology; values show $P(\text {COMGET} \mid \text {External})$. Additionally, we calculated relative genre prevalences and Gini coefficient across genres. Categories with less than 0.5\% relative frequency in the corpus were discarded (\textit {Rosamerica}: \textit {Speech}, \textit {Discogs}: \textit {Blues, Brass \& Military, Children's, Non-Music, Stage \& Screen}).\relax }{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Performance comparison of different learners (GLMNET, RDA, RF, GBM) on 20\% of the data set for low and medium \textit  {genre} granularity; plots show mean and standard error of $\text  {F1}_{\text  {macro}}$ across CV folds.\relax }}{10}{figure.caption.6}\protected@file@percent }
