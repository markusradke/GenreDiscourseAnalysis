@article{bhattacharjeeEffectDigitalSharing2007,
  title = {The {{Effect}} of {{Digital Sharing Technologies}} on {{Music Markets}}: {{A Survival Analysis}} of {{Albums}} on {{Ranking Charts}}},
  shorttitle = {The {{Effect}} of {{Digital Sharing Technologies}} on {{Music Markets}}},
  author = {Bhattacharjee, Sudip and Gopal, Ram D. and Lertwachara, Kaveepan and Marsden, James R. and Telang, Rahul},
  date = {2007},
  journaltitle = {Management Science},
  volume = {53},
  number = {9},
