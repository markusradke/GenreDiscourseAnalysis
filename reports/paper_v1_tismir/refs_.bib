@article{redepenningAmbivalentesAmerikaMartinu2011,
  title = {Ambivalentes {{Amerika}}: {{Martinů}}, {{Enescu}} Und {{Bartók}} in Den {{USA}}},
  shorttitle = {Ambivalentes {{Amerika}}},
  author = {Redepenning, Dorothea},
  date = {2011},
  journaltitle = {Osteuropa},
  volume = {61},
