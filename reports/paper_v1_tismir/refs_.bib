@inproceedings{natsiouAudioRepresentationsDeep2021,
  title = {Audio Representations for Deep Learning in Sound Synthesis: {{A}} Review},
  shorttitle = {Audio Representations for Deep Learning in Sound Synthesis},
  booktitle = {2021 {{IEEE}}/{{ACS}} 18th {{International Conference}} on {{Computer Systems}} and {{Applications}} ({{AICCSA}})},
  author = {Natsiou, Anastasia and O’Leary, Seán},
