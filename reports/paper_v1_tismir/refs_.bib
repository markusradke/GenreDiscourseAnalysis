@article{jangEncounteringCoverVersions2022,
  title = {Encountering {{Cover Versions}} of {{Songs Derived}} from {{Personal Music-Listening History Data}}: A {{Design}} and {{Field Trial}} of {{Musée}} in {{Homes}}},
