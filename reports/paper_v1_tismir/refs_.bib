@article{sanfilippoShuffleExploringReasons2020,
  title = {Do the Shuffle: {{Exploring}} Reasons for Music Listening through Shuffled Play},
  shorttitle = {Do the Shuffle},
  author = {Sanfilippo, Katie Rose M. and Spiro, Neta and Molina-Solana, Miguel and Lamont, Alexandra},
