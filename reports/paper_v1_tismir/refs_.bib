@article{dowdOrganizingMusicalCanon2002,
  title = {Organizing the Musical Canon: The Repertoires of Major {{U}}.{{S}}. Symphony Orchestras, 1842 to 1969},
  shorttitle = {Organizing the Musical Canon},
  author = {Dowd, Timothy J. and Liddle, Kathleen and Lupo, Kim and Borden, Anne},
