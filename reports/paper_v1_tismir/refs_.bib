  author = {{Rebecca Jane Scarratt} and Heggli, Ole Adrian and Vuust, Peter and Jespersen, Kira Vibe},
  editor = {Vattay, Gábor},
  date = {2023-01-18},
  journaltitle = {PLOS ONE},
