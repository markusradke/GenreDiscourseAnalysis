@article{wilderomDanceMarketsMovements2025,
  title = {The Dance of Markets and Movements: {{The}} Emergence and Development of Dance Genres in the {{US}}, {{UK}}, and the {{Netherlands}}, 1985–2005},
  shorttitle = {The Dance of Markets and Movements},
  author = {Wilderom, Rens and family=Venrooij, given=Alex, prefix=van, useprefix=true},
  date = {2025-04-01},
  journaltitle = {Poetics},
  shortjournal = {Poetics},
