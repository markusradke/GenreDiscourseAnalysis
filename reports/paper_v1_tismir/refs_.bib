@article{bullClassicalMusicGenre2021,
  title = {Classical Music as Genre: {{Hierarchies}} of Value within Freelance Classical Musicians’ Discourses},
  shorttitle = {Classical Music as Genre},
  author = {Bull, Anna and Scharff, Christina},
  date = {2021},
  journaltitle = {European Journal of Cultural Studies},
