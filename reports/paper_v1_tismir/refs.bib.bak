@inproceedings{kurniawanUtilizingMachineLearning2025,
  title = {Utilizing {{Machine Learning}} to {{Identify Mental Health Issues Based}} on {{Music Genre Preferences}}},
  booktitle = {2025 {{IEEE International Conference}} on {{Industry}} 4.0, {{Artificial Intelligence}}, and {{Communications Technology}} ({{IAICT}})},
  author = {Kurniawan, Janice Ashley and Nuzula, Putri Fatiha and Gunawan, Alexander Agung Santoso and Tedjasulaksana, Jeffrey Junior},
  year = 2025,
  month = jul,
  pages = {841--847},
  issn = {2834-8249},
  doi = {10.1109/IAICT65714.2025.11100633},
  urldate = {2025-08-12},
  abstract = {Mental health issues have been increasing worldwide, with a sharp rise in cases over the last 30 years. This shows the need for better ways to identify and address these problems. This study looks at how machine learning can help identify mental health conditions like anxiety, depression, insomnia, and OCD based on people's music preferences. Survey data on favorite music genres and self-reported mental health were analyzed using machine learning methods, including Logistic Regression, Decision Trees, and Gradient Boosting. Logistic Regression and Gradient Boosting worked the best, predicting anxiety with 32 \% accuracy after selecting key features. However, issues like unbalanced data and limited relevance of the information made it harder to improve the results. These findings highlight the correlation between the two, suggesting that while music and mental health might be connected, music preferences alone cannot accurately reflect a person's mental health condition, as causation does not work both ways.},
  keywords = {Anxiety disorders,Boosting,Data models,Data preprocessing,Decision trees,Depression,Fourth Industrial Revolution,genre,Logistic regression,machine learning,mental health,Mental health,music preferences,Surveys,ungelesen},
  file = {C\:\\Users\\marku\\Zotero\\storage\\GT5ZU5V3\\Kurniawan et al. - 2025 - Utilizing Machine Learning to Identify Mental Health Issues Based on Music Genre Preferences.pdf;C\:\\Users\\marku\\Zotero\\storage\\J9WK5MGL\\11100633.html}
}

