@incollection{hacquoilMetalMorphosisPhysicalGenre2025,
  title = {Metal-{{Morphosis}}: {{Physical}}, {{Genre}}, and {{Scene Transformation}} in {{Metal Music}}},
  shorttitle = {Metal-{{Morphosis}}},
  booktitle = {Transformation and {{Metamorphosis}} in {{Popular Culture}}},
  author = {Hacquoil, Timothy R.},
  year = 2025,
  publisher = {Routledge},
  abstract = {This chapter examines transformation in metal music through an analysis of physical, genre, and scene characteristics. Since the 1970s, metal music has evolved into a uniquely self-sufficient and dynamic genre. Heavy distortion on the electric guitar is generally considered a key element that dramatically alters the physical characteristics of the audio signal. Metal music also draws from and creates new production practices that firmly place change as a part of the genre. Furthermore, this chapter links physical characteristics to the scene itself, arguing that the objects (for example, the music or artwork) of a popular scene are best understood alongside their surrounding social contexts. Lastly, this chapter discusses how metamorphosis can be a useful tool for safely engaging in a transformative experience, which is one reason why the transformation trope is so appealing in popular culture.},
  keywords = {notext,ungelesen}
}

@article{hagenPlaylistExperiencePersonal2015,
  title = {The {{Playlist Experience}}: {{Personal Playlists}} in {{Music Streaming Services}}},
  shorttitle = {The {{Playlist Experience}}},
  author = {Hagen, Anja Nylund},
  year = 2015,
  month = oct,
  journal = {Popular Music and Society},
  volume = {38},
  number = {5},
  pages = {625--645},
  publisher = {Routledge},
  issn = {0300-7766},
  doi = {10.1080/03007766.2015.1021174},
  urldate = {2025-06-30},
  abstract = {Music streaming services encompass features that enable the organization of music into playlists. This article inquires how users describe and make sense of practices and experiences of creating, curating, maintaining, and using personal playlists. The analysis relies on a mixed-method study, including music-diary self-reports, online observations, and in-depth interviews with 12 heavy users of Spotify or/and WiMP Music. The findings suggest heterogeneous management of static and dynamic playlists based on structural and contextual schemes of aggregating music. User control motivates different playlist practices that demonstrate new ways of collecting music via streaming services but also derive from pre-digital collecting.},
  keywords = {ungelesen},
  file = {C:\Users\marku\Zotero\storage\NFBG84SM\03007766.2015.1021174.pdf}
}

@article{hagenSocialStreamingNavigating2016,
  title = {Social Streaming? {{Navigating}} Music as Personal and Social},
  shorttitle = {Social Streaming?},
  author = {Hagen, Anja N and L{\"u}ders, Marika},
  year = 2016,
  journal = {Convergence},
  volume = {23},
  number = {6},
  pages = {643--659},
  publisher = {SAGE Publications Ltd},
  issn = {1354-8565},
  doi = {10.1177/1354856516673298},
  urldate = {2025-04-28},
  abstract = {Music-streaming services embed social features that enable users to connect to one another and use music as social objects. This article examines how these features are experienced within negotiations of music as personal and social through the acts of sharing music and of following others. The analysis relies on 23 focus-group interviews with 124 Spotify and/or Tidal users and a mixed-method study including music-diary self-reports, online observation and interviews with 12 heavy users. Our findings suggest that users incorporate social awareness in non-sharing, selective-sharing and all-sharing approaches with strong, weak and absent ties. These ties are characterized by different configurations of social and music homophily. Negotiations of music as personal and social shape how music-streaming services are experienced.},
  langid = {english},
  keywords = {relevant,ungelesen},
  file = {C:\Users\marku\Zotero\storage\2JXEGI3Z\Hagen und Lüders - 2016 - Social streaming Navigating music as personal and.pdf}
}

