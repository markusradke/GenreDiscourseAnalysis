@article{kaneshiroCharacterizingListenerEngagement2017,
  title = {Characterizing {{Listener Engagement}} with {{Popular Songs Using Large-Scale Music Discovery Data}}},
  author = {Kaneshiro, Blair and Ruan, Feng and Baker, Casey W. and Berger, Jonathan},
  year = 2017,
  month = mar,
  journal = {Frontiers in Psychology},
  volume = {8},
  publisher = {Frontiers},
  issn = {1664-1078},
  doi = {10.3389/fpsyg.2017.00416},
  urldate = {2024-04-28},
  abstract = {{$<$}p{$>$}Music discovery in everyday situations has been facilitated in recent years by audio content recognition services such as Shazam. The widespread use of such services has produced a wealth of user data, specifying where and when a global audience takes action to learn more about music playing around them. Here, we analyze a large collection of Shazam queries of popular songs to study the relationship between the timing of queries and corresponding musical content. Our results reveal that the distribution of queries varies over the course of a song, and that salient musical events drive an increase in queries during a song. Furthermore, we find that the distribution of queries at the time of a song's release differs from the distribution following a song's peak and subsequent decline in popularity, possibly reflecting an evolution of user intent over the ``life cycle'' of a song. Finally, we derive insights into the data size needed to achieve consistent query distributions for individual songs. The combined findings of this study suggest that music discovery behavior, and other facets of the human experience of music, can be studied quantitatively using large-scale industrial data.{$<$}/p{$>$}},
  langid = {english},
  keywords = {multimedia search,music discovery,music information retrieval,Musical engagement,popular music,Shazam,Social Media,ungelesen},
  file = {C:\Users\marku\Zotero\storage\4NVG5XD9\Kaneshiro et al. - 2017 - Characterizing Listener Engagement with Popular So.pdf}
}

@article{karakayaliRecommendationSystemsTechnologies2018,
  title = {Recommendation {{Systems}} as {{Technologies}} of the {{Self}}: {{Algorithmic Control}} and the {{Formation}} of {{Music Taste}}},
  shorttitle = {Recommendation {{Systems}} as {{Technologies}} of the {{Self}}},
  author = {Karakayali, Nedim and Kostem, Burc and Galip, Idil},
  year = 2018,
