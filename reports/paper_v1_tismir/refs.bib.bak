@incollection{pentzoldOrdnungDiskurses2022,
  title = {{Die Ordnung des Diskurses}},
  booktitle = {{Schl\"usselwerke: Theorien (in) der Kommunikationswissenschaft}},
  author = {Pentzold, Christian},
  editor = {Spiller, Ralf and Rudeloff, Christian and D{\"o}bler, Thomas},
  year = 2022,
  pages = {289--308},
  publisher = {Springer Fachmedien},
  address = {Wiesbaden},
  doi = {10.1007/978-3-658-37354-2_19},
  urldate = {2025-09-24},
  abstract = {Der Beitrag stellt Michel Foucaults Schrift ,,Die Ordnung des Diskurses`` vor und diskutiert ihren Status als kommunikationswissenschaftliches Schl\"usselwerk. In ihr formuliert Foucault seine Ideen zur Verkn\"upfung von Diskursen und den in ihnen hervorgebrachten Wissensordnungen mit Machtverh\"altnissen. Damit wird der kurze Text zu einer wichtigen Referenz f\"ur die Analyse von diskursiven Praktiken und den Strategien, die darin hervorgebrachten Deutungen und die damit etablierten Positionen zu legitimieren. Nach einem kurzen Abriss von Foucaults intellektuellem Beitrag wird zun\"achst das Werk in seinen Grundz\"ugen vorgestellt. Im Anschluss erfolgt seine Verortung im Kontext von Foucaults Denkans\"atzen. Schlie\ss lich wird diskutiert, wie seine \"Uberlegung in Medienanalyse und Kommunikationsforschung eingebracht wurden.},
  isbn = {978-3-658-37354-2},
  langid = {ngerman},
  keywords = {Bedeutungsproduktion,Diskurs,Foucault,Gouvernementalitat,Hegemonie,Macht/Wissen,pass I,Subjektivierung},
  file = {C:\Users\marku\Zotero\storage\G39GUZSC\Pentzold - 2022 - Die Ordnung des Diskurses.pdf}
}

