@incollection{waghmareAmplifyingSongClustering2025,
  title = {Amplifying Song Clustering with {{Explainable AI}} and {{Hybrid Deep Learning}} for {{Industrial IoT}} Applications in Music Recommendation Systems},
  booktitle = {Explainable {{Artificial Intelligence-based Industrial Internet}} of {{Things}}},
  author = {Waghmare, Aishwarya Suryakant and Pande, Sagar Dhanraj},
  year = 2025,
  publisher = {CRC Press},
  abstract = {Personalization of content delivery constitutes the pillar of user engagement in modern digital ecosystems. It is already widespread practice in different industries like e-commerce, video streaming, and audio services; users are ever aware of this norm as they navigate their way through the recommendation systems. Spotify, the leader in the audio streaming industry with more than 456 million active users as of September 2022, hopes to improve its recommendation systems by leveraging advanced analytics techniques that classify songs into compact clusters. This clustering employs advanced algorithms to analyze innate similarities in various song features that may enable precise user-driven suggestions for the listener. This paper proposes a modern framework that integrates Explainable Artificial Intelligence (XAI), Industrial Internet of Things (IIoT) considerations, and Hybrid Deep Learning approaches for better song clustering. Drawing upon Exploratory Data Analysis, insightful feature engineering, and dimensionality reduction from autoencoders, the method proposed in this study pursues to tap into the deep musical attributes that are so critical to improving performance in clustering. Moreover, XAI techniques, particularly SHAP (SHapley Additive ExPlanations), brought in to improve their interpretability, shedding light on how these cohorts formed. The framework also considers IIoT implications, namely, real-time data processing originating from smart devices, thus situating the results within the larger view of a scalable industrial framework. The results indicate that clustering accuracy improved while enhancing interpretability and providing actionable insights into the categorization of songs and the features that are driving those classifications. This methodology sets the platform for a scalable explainable data-driven recommendation system responding to the demands of streaming platforms and their remarkably diverse communities of users.},
  keywords = {notext,ungelesen}
}

