@article{baughmanMixtureModelFramework2007,
  title = {Mixture {{Model Framework Facilitates Understanding}} of {{Zero-Inflated}} and {{Hurdle Models}} for {{Count Data}}},
  author = {Baughman, A. L.},
  year = 2007,
  month = aug,
  journal = {Journal of Biopharmaceutical Statistics},
  volume = {17},
  number = {5},
  pages = {943--946},
  publisher = {Taylor \& Francis},
  issn = {1054-3406},
  doi = {10.1080/10543400701514098},
  urldate = {2025-06-04},
  abstract = {In this note, we comment on the zero-inflated and hurdle models for count data presented by Rose et al., 2006, J. Biopharma. Stat. 16:463--481. By viewing these models as finite mixture models, one gains a better understanding of the components of the models, including assumptions about the latent variable(s) in the finite mixture models. Deciding whether a zero-inflated or hurdle model is appropriate for a given data set requires close collaboration with subject matter experts. For instance, in modeling vaccine adverse event count data, the pharmacokinetic rationale for the occurrence of an adverse event and the likelihood of detecting or reporting the adverse event are important considerations for mixture model development.},
  pmid = {17885875},
  keywords = {Count data,Finite mixture model,Hurdle model,Zero-inflated model},
