@inproceedings{schreiberImprovingGenreAnnotations2015,
  title = {Improving {{Genre Annotations}} for the {{Million Song Dataset}}},
  booktitle = {16th {{International Society}} for {{Music Information Retrieval Conference}}},
  author = {Schreiber, Hendrik},
  year = 2015,
  abstract = {Any automatic music genre recognition (MGR) system must show its value in tests against a ground truth dataset. Recently, the public dataset most often used for this purpose has been proven problematic, because of mislabeling, duplications, and its relatively small size. Another dataset, the Million Song Dataset (MSD), a collection of features and metadata for one million tracks, unfortunately does not contain readily accessible genre labels. Therefore, multiple attempts have been made to add song-level genre annotations, which are required for supervised machine learning tasks. Thus far, the quality of these annotations has not been evaluated.},
  langid = {english},
  keywords = {hochrelevant,pass I},
  file = {C:\Users\marku\Zotero\storage\7XZWRY9F\Schreiber - IMPROVING GENRE ANNOTATIONS FOR THE MILLION SONG DATASET.pdf}
}

