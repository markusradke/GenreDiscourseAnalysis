@article{vanlissaRecommendedPracticesLatent2024,
  title = {Recommended {{Practices}} in {{Latent Class Analysis Using}} the {{Open-Source R-Package tidySEM}}},
  author = {Van Lissa, C. J. and , M., Garnier-Villarreal and {and Anadria}, D.},
  year = 2024,
  month = may,
  journal = {Structural Equation Modeling: A Multidisciplinary Journal},
  volume = {31},
  number = {3},
  pages = {526--534},
  publisher = {Routledge},
  issn = {1070-5511},
  doi = {10.1080/10705511.2023.2250920},
  urldate = {2025-06-04},
  abstract = {Latent class analysis (LCA) refers to techniques for identifying groups in data based on a parametric model. Examples include mixture models, LCA with ordinal indicators, and latent class growth analysis. Despite its popularity, there is limited guidance with respect to decisions that must be made when conducting and reporting LCA. Moreover, there is a lack of user-friendly open-source implementations. Based on contemporary academic discourse, this paper introduces recommendations for LCA which are summarized in the SMART-LCA checklist: Standards for More Accuracy in Reporting of different Types of Latent Class Analysis. The free open-source R-package package tidySEM implements the practices recommended here. It is easy for beginners to adopt thanks to user-friendly wrapper functions, and yet remains relevant for expert users as its models are integrated within the OpenMx structural equation modeling framework and remain fully customizable. The Appendices and tidySEM package vignettes include tutorial examples of common applications of LCA.},
  keywords = {Free open-source software,latent class analysis,mixture models,recommended practices,verzettelt},
  file = {C:\Users\marku\Zotero\storage\6F55VFMY\Van Lissa et al. - 2024 - Recommended Practices in Latent Class Analysis Usi.pdf}
}

@article{vanvenrooijCategoricalAmbiguityCultural2018,
  title = {Categorical Ambiguity in Cultural Fields: {{The}} Effects of Genre Fuzziness in Popular Music},
  shorttitle = {Categorical Ambiguity in Cultural Fields},
  author = {{van Venrooij}, Alex and Schmutz, Vaughn},
  year = 2018,
  journal = {Poetics},
  volume = {66},
  pages = {1--18},
  issn = {0304-422X},
  doi = {10.1016/j.poetic.2018.02.001},
  urldate = {2024-02-05},
  abstract = {Recent studies find that objects that do not clearly fit within the categories of their field are penalized by relevant audiences. We examine whether this `categorical imperative' is dependent on the symbolic and institutional structure of fields by comparing the effects of genre ambiguity across two popular music subfields. The results show that genre ambiguity has a negative effect within the commercial subfield, but not in the artistic subfield. The effects of genre fuzziness on the reception of popular music are also contingent on the producing organization (major vs. independent) and the types of media outlets that review an album. We find that certain forms of ambiguity can enhance the critical reception of a popular music album. In general, our findings support DiMaggio's theory regarding variation in the boundary strength of classification systems.},
  keywords = {Categories,Fields,Genres,Popular music,ungelesen},
  annotation = {GSCC: 0000061 2025-07-02T06:43:30.757Z 0.16},
  file = {C:\Users\marku\Zotero\storage\5H8Z4CZQ\van Venrooij und Schmutz - 2018 - Categorical ambiguity in cultural fields The effe.pdf}
}

@article{varnumWhyAreSong2021,
  title = {Why Are Song Lyrics Becoming Simpler? A Time Series Analysis of Lyrical Complexity in Six Decades of {{American}} Popular Music},
  shorttitle = {Why Are Song Lyrics Becoming Simpler?},
  author = {Varnum, Michael E. W. and Krems, Jaimie Arona and Morris, Colin and Wormley, Alexandra and Grossmann, Igor},
  year = 2021,
  month = jan,
  journal = {PLOS ONE},
  volume = {16},
  number = {1},
  pages = {e0244576},
  publisher = {Public Library of Science},
  issn = {1932-6203},
  doi = {10.1371/journal.pone.0244576},
  urldate = {2023-05-07},
  abstract = {Song lyrics are rich in meaning. In recent years, the lyrical content of popular songs has been used as an index of culture's shifting norms, affect, and values. One particular, newly uncovered, trend is that lyrics of popular songs have become increasingly simple over time. Why might this be? Here, we test the idea that increasing lyrical simplicity is accompanied by a widening array of novel song choices. We do so by using six decades (1958--2016) of popular music in the United States (N = 14,661 songs), controlling for multiple well-studied ecological and cultural factors plausibly linked to shifts in lyrical simplicity (e.g., resource availability, pathogen prevalence, rising individualism). In years when more novel song choices were produced, the average lyrical simplicity of the songs entering U.S. billboard charts was greater. This cross-temporal relationship was robust when controlling for a range of cultural and ecological factors and employing multiverse analyses to control for potentially confounding influence of temporal autocorrelation. Finally, simpler songs entering the charts were more successful, reaching higher chart positions, especially in years when more novel songs were produced. The present results suggest that cultural transmission depends on the amount of novel choices in the information landscape.},
  langid = {english},
  keywords = {ungelesen},
  file = {C:\Users\marku\Zotero\storage\ZZ64NVIU\Varnum et al. - 2021 - Why are song lyrics becoming simpler a time serie.pdf}
}

