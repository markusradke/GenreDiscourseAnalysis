@article{ouelletStrikingMajorChord2025,
  title = {Striking a Major Chord: Music Preferences as Predictors of Vote Intentions in {{Canada}}},
  shorttitle = {Striking a Major Chord},
  author = {Ouellet, Catherine and Fr{\'e}chet, Nadjim and Coulombe, Simon},
  year = 2025,
  month = aug,
  journal = {Acta Politica},
  issn = {1741-1416},
  doi = {10.1057/s41269-025-00397-3},
  urldate = {2025-09-04},
  abstract = {Music is arguably one of the most meaningful and widespread forms of communication. Music is also a medium for people's self-definition and identification. Extensive evidence suggests that musical taste reveals deeper attributes, such as socioeconomic position and individual characteristics, due to the various functions that music fulfills in our lives. This research draws on unique data collected during the 2021 Canadian federal election and the 2022 Quebec general election, using digital data collection to investigate how fans of different music genres might differ in their voting intentions, personality traits, and sociodemographic characteristics. By linking the answers to a single question on Datagotchi to MusicBrainz, an open database, we are able to collect a wealth of other music-related information on users. Among significant findings, we discover that music preferences vary widely across socioeconomic groups, and that certain personality traits are clearly associated with musical preferences, particularly for specific music fan groups. Significant correlations also emerge between music preferences and vote intentions, with Conservatives standing out from other groups. These findings suggest that music preferences convey significant information and are worthy of scientific attention by social scientists. More generally, this analysis aims to provoke a reflection on the ethical issues raised by the value of musical (and more broadly lifestyle) data in a digital world.},
  langid = {english},
  keywords = {Canadian politics,Electoral behavior,Musical taste,Personality traits,ungelesen,Vote choice},
  file = {C:\Users\marku\Zotero\storage\FAI6W7FX\Ouellet et al. - 2025 - Striking a major chord music preferences as predictors of vote intentions in Canada.pdf}
}

@incollection{pachetTaxonomyMusicalGenres2000,
  title = {A Taxonomy of Musical Genres},
  booktitle = {Content-{{Based Multimedia Information Access}} - {{Volume}} 2},
  author = {Pachet, Fran{\c c}ois and {View Profile} and Cazaly, Daniel and {View Profile}},
  year = 2000,
  month = apr,
  series = {Guide {{Proceedings}}},
  pages = {1238--1245},
  doi = {10.5555/2856151.2856177},
  urldate = {2025-12-04},
  abstract = {The recent progress of Electronic Music Distribution creates a natural pressure for fine-grained musical metadata. This metadata is needed to provide music distribution services which are able to cope with the mere size of music catalogues, and the desire of users to access music titles by similarity. In this context, we describe a project of a global music title metadatabase, and focus in the particular "genre" descriptor. We analyze existing taxonomies of musical genre as found in the music industry and on the Internet, and stress on their inconsistencies. We describe a novel music genre taxonomy based on a few guiding principles, and report on the process of building this taxonomy.},
  keywords = {pass I,relevant},
  file = {C:\Users\marku\Zotero\storage\JV3BCITK\Pachet et al. - 2000 - A taxonomy of musical genres.pdf}
}

